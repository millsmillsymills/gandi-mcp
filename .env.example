# Gandi MCP Server Configuration
# Copy to .env and fill in your values.

# ─── Authentication ──────────────────────────────────────────────────────────
# Personal Access Token (PAT) from https://admin.gandi.net/
# Legacy 24-char API keys are no longer accepted by the v5 API (as of 2025).
GANDI_TOKEN=

# Optional sharing_id (UUID of an organization). Applied to every request as
# the ?sharing_id= query parameter when set, scoping reads and writes to that
# org. Leave blank to use the token owner's default scope.
# GANDI_SHARING_ID=

# ─── Safety gates (defense-in-depth) ─────────────────────────────────────────
# Mode: "readonly" (default) or "readwrite"
# In readonly mode, ALL write tools are completely hidden from MCP clients.
GANDI_MODE=readonly

# Purchasing gate. Independent of GANDI_MODE. When false (default), tools that
# spend money — domain registration, renewal, transfer-in, certificate
# issuance, mailbox slot creation, etc. — are hidden from the MCP client AND
# rejected at runtime. Must be BOTH readwrite AND allow_purchases=true for
# purchase tools to be callable.
GANDI_ALLOW_PURCHASES=false

# ─── General ─────────────────────────────────────────────────────────────────
GANDI_API_BASE_URL=https://api.gandi.net
GANDI_REQUEST_TIMEOUT=30        # Request timeout in seconds
GANDI_MAX_RETRIES=3             # Total request attempts including the first (min 1 = no retry)
